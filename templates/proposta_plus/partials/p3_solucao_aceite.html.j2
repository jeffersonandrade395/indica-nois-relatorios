<div class="pp-page">
  <!-- (label de debug removido) -->

  <!-- Header -->
  <div class="pp-header">
    <div class="pp-logo-row">
      <div class="pp-logo-mark">IN</div>
      <span class="pp-logo-name">Indica Nóis</span>
    </div>
    <span class="pp-header-cnpj">{{ meta.razao_social_completa }}</span>
  </div>

  <!-- Eyebrow + Headline -->
  <div class="pp-eyebrow">A SOLUÇÃO</div>
  <div style="font-size: 28px; font-weight: 900; color: #1A1A1A; line-height: 1.05; margin-bottom: 14px; letter-spacing: -0.5px;">
    Plano Plus <span class="pp-accent">· Indica Nóis</span>
  </div>

  <!-- Card preço -->
  <div style="background: #F5F2EC; border-radius: 10px; padding: 14px 22px; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between;">
    <div>
      <div style="font-size: 36px; font-weight: 900; color: #F04E23; line-height: 1; letter-spacing: -1px;">
        {{ oferta.preco_fmt }}<span style="font-size: 18px; color: #757575; font-weight: 600;"> /mês</span>
      </div>
      <div style="font-size: 11px; color: #757575; margin-top: 4px;">
        {% if oferta.modalidade == 'anual' %}
          {{ oferta.modalidade_fmt }} · economia vs. mensal
        {% else %}
          {{ oferta.modalidade_fmt }} · sem fidelidade a desconto
        {% endif %}
      </div>
    </div>
    <div style="text-align: right; font-size: 10px; color: #444441; line-height: 1.8;">
      <div>Contrato 12 meses</div>
      <div>SLA 24h</div>
      <div style="color: #1CB85A; font-weight: 700;">Trial de 14 dias</div>
    </div>
  </div>

  <!-- O que você opera -->
  <div style="font-size: 10px; letter-spacing: 2px; color: #1A1A1A; font-weight: 800; margin-bottom: 6px;">O QUE VOCÊ OPERA</div>

  <div class="pp-feat-grid" style="margin-bottom: 10px;">
    <div class="pp-feat-card">
      <div class="pp-feat-eyebrow">CAMPANHAS</div>
      <div style="font-size: 11px; color: #1A1A1A; line-height: 1.45;">
        <div style="font-weight: 700;">5 ativas em paralelo</div>
        <div style="color: #757575;">Fixa, Escada, Ranking, Unificada</div>
      </div>
    </div>

    <div class="pp-feat-card">
      <div class="pp-feat-eyebrow">PARTICIPANTES</div>
      <div style="font-size: 11px; color: #1A1A1A; line-height: 1.45;">
        <div style="font-weight: 700;">Até 2.000</div>
        <div style="color: #757575;">Import/Export CSV</div>
      </div>
    </div>

    <div class="pp-feat-card">
      <div class="pp-feat-eyebrow">RECOMPENSAS</div>
      <div style="font-size: 11px; color: #1A1A1A; line-height: 1.45;">
        <div style="font-weight: 700;">6 modalidades disponíveis</div>
        <div style="color: #757575;">PIX, Cupom, Desconto, Brinde, Lead</div>
      </div>
    </div>

    <div class="pp-feat-card">
      <div class="pp-feat-eyebrow">GESTÃO</div>
      <div style="font-size: 11px; color: #1A1A1A; line-height: 1.45;">
        <div style="font-weight: 700;">Aprovação em lote</div>
        <div style="color: #757575;">Dashboard real-time + Insights</div>
      </div>
    </div>

    <div class="pp-feat-card">
      <div class="pp-feat-eyebrow">INTEGRAÇÃO</div>
      <div style="font-size: 11px; color: #1A1A1A; line-height: 1.45;">
        <div style="font-weight: 700;">API Aberta + Webhooks</div>
        <div style="color: #757575;">/v1/ com API Key</div>
      </div>
    </div>

    <div class="pp-feat-card-dark">
      <div class="pp-feat-eyebrow">FINANCEIRO · BYO-ASAAS</div>
      <div style="font-size: 11px; color: white; line-height: 1.45;">
        <div style="font-weight: 700;">Controle total da operação</div>
        <div style="color: #B4B2A9;">Zero intermediação financeira</div>
      </div>
    </div>
  </div>

  <!-- O que cabe ao cliente -->
  <div style="border-top: 1px solid #EAE6DF; padding-top: 10px; margin-bottom: 10px;">
    <div style="font-size: 10px; letter-spacing: 2px; color: #1A1A1A; font-weight: 800; margin-bottom: 6px;">O QUE CABE AO CLIENTE</div>

    <div style="font-size: 11px; color: #444441; line-height: 1.5; margin-bottom: 8px;">
      Plus é plataforma auto-operada. Você configura campanhas, aprova indicações e analisa métricas em tempo real. Para operação com consultoria dedicada, pesquisa de recompensa estruturada e especialista de performance, o plano indicado é o PRO.
    </div>

    <div style="background: white; border: 1px solid #EAE6DF; border-radius: 6px; padding: 10px 16px; margin-bottom: 4px;">
      <div style="font-size: 9px; color: #757575; font-weight: 700; letter-spacing: 1px; margin-bottom: 4px;">CHECKLIST DE ATIVAÇÃO</div>
      <div class="pp-checklist">
        <div>&#9633; &nbsp;Conta Asaas aberta (BYO · self-service ~30 min)</div>
        <div>&#9633; &nbsp;Primeira campanha configurada e publicada</div>
        <div>&#9633; &nbsp;Base de clientes importada via CSV</div>
        <div>&#9633; &nbsp;Link de indicação distribuído à base</div>
        <div>&#9633; &nbsp;Primeira rodada de aprovação de indicações</div>
      </div>
    </div>

    <div style="font-size: 10px; color: #757575; font-style: italic; line-height: 1.4;">
      Tempo típico de setup: 2 a 5 dias úteis. Suporte via SLA 24h.
    </div>
  </div>

  <!-- Quando Plus, quando PRO -->
  <div style="background: #FCEDE7; border-left: 3px solid #F04E23; border-radius: 0 6px 6px 0; padding: 10px 16px; margin-bottom: 12px;">
    <div style="font-size: 10px; letter-spacing: 2px; color: #C93D1A; font-weight: 800; margin-bottom: 6px;">QUANDO PLUS, QUANDO PRO</div>
    <div class="pp-when-grid">
      <div>
        <div style="font-size: 10.5px; font-weight: 700; color: #1A1A1A; margin-bottom: 3px;">Plus é o plano certo se:</div>
        <div style="font-size: 10px; color: #444441; line-height: 1.5;">
          · Base ativa entre 500 e 2.000 clientes<br>
          · Time interno capacitado para operar<br>
          · Programa já em maturação ou disposto a testar
        </div>
      </div>
      <div>
        <div style="font-size: 10.5px; font-weight: 700; color: #1A1A1A; margin-bottom: 3px;">PRO é o plano certo se:</div>
        <div style="font-size: 10px; color: #444441; line-height: 1.5;">
          · Base acima de 2.000 clientes<br>
          · Pesquisa estruturada + Calculadora de CAC<br>
          · Especialista + Metodologia completa
        </div>
      </div>
    </div>
  </div>

  <!-- Seção aceite — borda preta superior -->
  <div style="border-top: 2px solid #1A1A1A; padding-top: 12px; margin-bottom: 12px;">
    <div style="font-size: 11px; letter-spacing: 2px; color: #F04E23; font-weight: 800; margin-bottom: 8px;">COMO ACEITAR</div>
    <div style="font-size: 13px; color: #1A1A1A; line-height: 1.45; margin-bottom: 8px;">
      Responda este e-mail com <strong>"Aceito a proposta Plus"</strong> ou retorne esta proposta assinada digitalmente. Ao aceitar, enviamos contrato formal de 12 meses e credenciais de acesso em até 24h úteis.
    </div>

    <div style="font-size: 11px; color: #444441; line-height: 1.6; margin-bottom: 6px;">
      <strong style="color: #1A1A1A;">Validade:</strong> {{ metadata.validade_fmt }} · <strong style="color: #1A1A1A;">Dúvidas?</strong> <span style="color: #F04E23;">cal.com/jefferson-andrade-fbn3w7/30min</span>
    </div>

    <div style="font-size: 10px; color: #757575; line-height: 1.5; padding-top: 8px; border-top: 1px dashed #EAE6DF;">
      <strong style="color: #444441;">Condições:</strong> Contrato 12 meses · Boleto ou cartão recorrente · Pró-rata + mês cheio no primeiro ciclo · Reajuste IPCA anual · Rescisão antecipada 20% sobre saldo
    </div>
  </div>

  <!-- Assinatura -->
  <div style="position: absolute; bottom: 25mm; left: 22mm; right: 22mm; padding-top: 16px; border-top: 1px solid #EAE6DF;">
    <div class="pp-sig">Jefferson Andrade</div>
    <div class="pp-sig-role">Founder, Indica Nóis</div>
  </div>

  <div class="pp-footer">
    <div>Indica Nóis · Proposta Plus · Confidencial</div>
    <div>Página 3 de 3</div>
  </div>
</div>
