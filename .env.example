# Google Drive — persistência de contextos de relatórios
# 1. Habilite a Drive API no Google Cloud Console
# 2. Crie/reutilize uma service account e baixe o JSON de credenciais
# 3. Crie a pasta "IndicaNois_Contextos" no Drive e compartilhe com o e-mail da service account
# 4. Copie este arquivo para .env e preencha os valores abaixo

GOOGLE_DRIVE_CREDENTIALS_PATH=config/google_drive_credentials.json
GOOGLE_DRIVE_FOLDER_ID=<ID_DA_PASTA_IndicaNois_Contextos>
